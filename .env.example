# Copy to .env and fill in real values. Do not commit .env.

# Server (local dev only)
PORT=3000

# Comma-separated round-robin recipients
TEAM_EMAILS=teammember1@example.com,teammember2@example.com

# Outbound email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-sender@example.com
SMTP_PASS=your-app-password-or-smtp-password
MAIL_FROM=your-sender@example.com
