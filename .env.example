# Copy to .env and fill in real values. Do not commit .env.

# Server (local dev only)
PORT=3000

# Comma-separated round-robin recipients
TEAM_EMAILS=teammember1@example.com,teammember2@example.com

# Outbound email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-sender@example.com
SMTP_PASS=your-app-password-or-smtp-password
MAIL_FROM=your-sender@example.com

# Google Sheet logging (optional — append each application ID + details)
GOOGLE_SHEET_ID=your-spreadsheet-id-from-the-url
GOOGLE_SHEET_TAB=Applications
# Local dev: path to downloaded service-account JSON (gitignored)
GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json
# Netlify: paste the full JSON key as one line, or base64-encode the file
# GOOGLE_SERVICE_ACCOUNT_JSON=
